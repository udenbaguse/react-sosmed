// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id    Int    @id @default(autoincrement()) 
  fillname String @db.VarChar(255) 
  email String @unique @db.VarChar(255)
  username String @unique @db.VarChar(255)
  password String @db.VarChar(255)
  bio String? @db.Text
  image String? @db.VarChar(255)
  imageId String? @db.VarChar(255)
  followingCount Int @db.Integer @default(0)
  followerCount Int @db.Integer @default(0)
  postsCount Int @db.Integer @default(0)
  createdAt DateTime @default(now())
  posts Post[]
  comments Comment[]
  bookmarks Bookmark[]
  likes Likes[]
  followings Follow[] @relation("Followings")
  followers Follow[] @relation("Followers")
} 

model Post {
  id Int @id @default(autoincrement())
  userId Int @db.Integer
  user User @relation(fields: [userId], references: [id])
  image String @db.VarChar(255)
  imageId String @db.VarChar(255)
  caption String @db.Text
  commentCount Int @db.Integer @default(0)
  likeCount Int @db.Integer @default(0)
  createdAt DateTime @default(now())
  comments Comment[]
  likes Likes[]
  bookmarks Bookmark[]
}

model Comment {
  id Int @id @default(autoincrement())
  userId Int @db.Integer
  user User @relation(fields: [userId], references: [id])
  postId Int 
  post Post @relation(fields: [postId], references: [id])
  content String @db.Text
  createdAt DateTime @default(now())
}

model Bookmark {
  userId Int @db.Integer
  user User @relation(fields: [userId], references: [id])
  postId Int 
  post Post @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())
  @@id([userId, postId])
}

model Likes {
  userId Int @db.Integer
  user User @relation(fields: [userId], references: [id])
  postId Int 
  post Post @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())
  @@id([userId, postId])
}

model Follow {
  followerId Int
  follower User @relation("Followers",fields: [followerId], references: [id])
  followingId Int
  following User @relation("Followings" ,fields: [followingId], references: [id])
  createdAt DateTime @default(now())
  @@id([followerId, followingId])
}
